{
  "name": "zyneth",
  "version": "0.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "config/*",
      "packages/*",
      "apis/*",
      "apps/*"
    ]
  },
  "scripts": {
    "check": "turbo run check --concurrency=100%",
    "check:apps": "turbo run check --concurrency=100% --filter='./apps/*'",
    "check:packages": "turbo run check --concurrency=100% --filter='./packages/*'",
    "check:apis": "turbo run check --concurrency=100% --filter='./apis/*'",
    "dev": "turbo run dev --parallel --continue",
    "dev:web": "turbo watch dev --filter=@zyneth/web",
    "build": "turbo run build",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "test": "turbo run test --concurrency=100%",
    "prepare": "test -d .git && lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@types/bun": "1.3.5",
    "lefthook": "2.0.12",
    "turbo": "2.7.1",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.5",
  "trustedDependencies": [
    "@biomejs/biome",
    "sharp",
    "unrs-resolver"
  ]
}
