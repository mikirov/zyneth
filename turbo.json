{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["APP_ENV", "CI", "NODE_ENV", "DATABASE_URL"],
  "globalDependencies": ["tsconfig.json"],
  "tasks": {
    "build": {
      "outputs": ["dist/**/*"],
      "dependsOn": ["^build"],
      "cache": true
    },
    "check": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "start": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false,
      "outputs": ["migrations/**/*"]
    },
    "db:migrate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    }
  }
}
