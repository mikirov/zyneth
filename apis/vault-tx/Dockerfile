FROM oven/bun:1.3.5

WORKDIR /app
COPY . .
RUN bun install --ignore-scripts

ARG TURBO_TEAM
ENV TURBO_TEAM=$TURBO_TEAM
ARG TURBO_TOKEN
ENV TURBO_TOKEN=$TURBO_TOKEN

ARG RPC_URL
ENV RPC_URL=$RPC_URL
ARG PORT
ENV PORT=$PORT
ARG CORS_ORIGIN
ENV CORS_ORIGIN=$CORS_ORIGIN
ARG REDIS_URL
ENV REDIS_URL=$REDIS_URL

EXPOSE 3004

CMD ["bun", "run", "--cwd", "apis/vault-tx", "start"]
