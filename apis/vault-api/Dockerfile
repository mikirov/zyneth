FROM oven/bun:1.3.5

WORKDIR /app
COPY . .
RUN bun install --ignore-scripts

ARG TURBO_TEAM
ENV TURBO_TEAM=$TURBO_TEAM
ARG TURBO_TOKEN
ENV TURBO_TOKEN=$TURBO_TOKEN

ARG PONDER_DATABASE_URL
ENV PONDER_DATABASE_URL=$PONDER_DATABASE_URL
ARG PORT
ENV PORT=$PORT
ARG CORS_ORIGIN
ENV CORS_ORIGIN=$CORS_ORIGIN

EXPOSE 3003

CMD ["bun", "run", "--cwd", "apis/vault-api", "start"]
